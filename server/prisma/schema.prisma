// Badminton SaaS Platform - Database Schema
// PostgreSQL 16 + Row-level tenant_id isolation
// See docs/04-数据库设计.md for full design rationale

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 1. Platform & Tenant
// ============================================================

model Tenant {
  id            BigInt    @id @default(autoincrement())
  code          String    @unique @db.VarChar(32)
  name          String    @db.VarChar(64)
  logoUrl       String?   @map("logo_url") @db.Text
  contactName   String?   @map("contact_name") @db.VarChar(32)
  contactPhone  String?   @map("contact_phone") @db.VarChar(20)
  licenseNo     String?   @map("license_no") @db.VarChar(64)
  status        String    @default("pending") @db.VarChar(16) // pending, active, suspended, rejected
  plan          String    @default("trial") @db.VarChar(32)
  planExpiredAt DateTime? @map("plan_expired_at") @db.Timestamptz()
  settings      Json      @default("{}")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz()

  @@index([status], map: "idx_tenants_status")
  @@map("tenants")
}

model TenantStaff {
  id        BigInt    @id @default(autoincrement())
  tenantId  BigInt    @map("tenant_id")
  userId    BigInt    @map("user_id")
  roleId    BigInt    @map("role_id")
  isOwner   Boolean   @default(false) @map("is_owner")
  status    String    @default("active") @db.VarChar(16) // active, inactive, left
  joinedAt  DateTime  @default(now()) @map("joined_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  role Role @relation(fields: [roleId], references: [id])

  @@unique([tenantId, userId], map: "uk_tenant_staffs_tenant_user")
  @@index([tenantId, roleId], map: "idx_tenant_staffs_tenant_role")
  @@map("tenant_staffs")
}

model Role {
  id        BigInt   @id @default(autoincrement())
  tenantId  BigInt   @default(0) @map("tenant_id")
  code      String   @db.VarChar(64)
  name      String   @db.VarChar(64)
  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  rolePermissions RolePermission[]
  tenantStaffs    TenantStaff[]

  @@unique([tenantId, code], map: "uk_roles_tenant_code")
  @@map("roles")
}

model Permission {
  id       BigInt @id @default(autoincrement())
  code     String @unique @db.VarChar(128)
  name     String @db.VarChar(128)
  module   String @db.VarChar(64)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       BigInt @map("role_id")
  permissionId BigInt @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================
// 2. User & Member
// ============================================================

model User {
  id           BigInt    @id @default(autoincrement())
  phone        String?   @db.VarChar(20)
  phoneHash    String?   @map("phone_hash") @db.Char(64)
  email        String?   @db.VarChar(128)
  nickname     String?   @db.VarChar(64)
  avatarUrl    String?   @map("avatar_url") @db.Text
  gender       Int?      @default(0) @db.SmallInt
  birthday     DateTime? @db.Date
  unionId      String?   @unique @map("union_id") @db.VarChar(64)
  realName     Bytes?    @map("real_name")
  idCard       Bytes?    @map("id_card")
  realVerified Boolean   @default(false) @map("real_verified")
  passwordHash String?   @map("password_hash") @db.Text
  status       String    @default("active") @db.VarChar(16) // active, frozen, deleted
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz()

  @@index([phoneHash], map: "uk_users_phone_hash")
  @@map("users")
}

model UserOauthBinding {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  provider  String   @db.VarChar(32)
  openId    String   @map("open_id") @db.VarChar(128)
  extra     Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([provider, openId], map: "uk_user_oauth_provider_openid")
  @@index([userId], map: "idx_user_oauth_user")
  @@map("user_oauth_bindings")
}

model Member {
  id               BigInt    @id @default(autoincrement())
  tenantId         BigInt    @map("tenant_id")
  userId           BigInt    @map("user_id")
  memberNo         String    @map("member_no") @db.VarChar(32)
  level            Int       @default(1) @db.SmallInt
  points           Int       @default(0)
  totalSpentAmount Decimal   @default(0) @map("total_spent_amount") @db.Decimal(12, 2)
  source           String?   @db.VarChar(32)
  referrerId       BigInt?   @map("referrer_id")
  tags             Json      @default("[]")
  note             String?   @db.Text
  blacklisted      Boolean   @default(false)
  joinedAt         DateTime  @default(now()) @map("joined_at") @db.Timestamptz()
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz()

  @@unique([tenantId, userId], map: "uk_members_tenant_user")
  @@unique([tenantId, memberNo], map: "uk_members_tenant_member_no")
  @@index([tenantId, level], map: "idx_members_tenant_level")
  @@map("members")
}

model MemberCard {
  id           BigInt    @id @default(autoincrement())
  tenantId     BigInt    @map("tenant_id")
  memberId     BigInt    @map("member_id")
  cardType     String    @map("card_type") @db.VarChar(16) // count, period
  cardName     String    @map("card_name") @db.VarChar(64)
  totalCount   Int?      @map("total_count")
  usedCount    Int       @default(0) @map("used_count")
  validFrom    DateTime? @map("valid_from") @db.Timestamptz()
  validTo      DateTime? @map("valid_to") @db.Timestamptz()
  status       String    @default("active") @db.VarChar(16) // active, used_up, expired, void
  sourceOrderId BigInt?  @map("source_order_id")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz()

  @@index([tenantId, memberId, status], map: "idx_member_cards_tenant_member_status")
  @@map("member_cards")
}

// ============================================================
// 3. Venue & Court
// ============================================================

model VenuePartner {
  id           BigInt   @id @default(autoincrement())
  name         String   @db.VarChar(128)
  contactName  String?  @map("contact_name") @db.VarChar(64)
  contactPhone String?  @map("contact_phone") @db.VarChar(20)
  address      String?  @db.Text
  licenseNo    String?  @map("license_no") @db.VarChar(64)
  status       String   @default("active") @db.VarChar(16) // active, inactive
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([status], map: "idx_venue_partners_status")
  @@map("venue_partners")
}

model Venue {
  id         BigInt    @id @default(autoincrement())
  tenantId   BigInt    @default(0) @map("tenant_id")
  partnerId  BigInt?   @map("partner_id")
  name       String    @db.VarChar(128)
  city       String?   @db.VarChar(32)
  district   String?   @db.VarChar(32)
  address    String?   @db.Text
  latitude   Decimal?  @db.Decimal(10, 7)
  longitude  Decimal?  @db.Decimal(10, 7)
  openRules  Json      @default("{}") @map("open_rules")
  status     String    @default("active") @db.VarChar(16) // active, inactive
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz()

  @@index([tenantId, status], map: "idx_venues_tenant_status")
  @@index([partnerId], map: "idx_venues_partner")
  @@map("venues")
}

model ClubVenueRelation {
  id             BigInt    @id @default(autoincrement())
  tenantId       BigInt    @map("tenant_id")
  venueId        BigInt    @map("venue_id")
  relationType   String    @default("partner") @map("relation_type") @db.VarChar(16) // self_owned, partner
  settlementRule Json      @default("{}") @map("settlement_rule")
  allowedCourts  Json?     @map("allowed_courts")
  status         String    @default("active") @db.VarChar(16) // active, paused
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz()

  @@unique([tenantId, venueId], map: "uk_club_venue_relations_tenant_venue")
  @@map("club_venue_relations")
}

model Court {
  id        BigInt    @id @default(autoincrement())
  tenantId  BigInt    @map("tenant_id")
  venueId   BigInt    @map("venue_id")
  code      String    @db.VarChar(32)
  type      String    @default("standard") @db.VarChar(16) // standard, training
  basePrice Decimal   @default(0) @map("base_price") @db.Decimal(8, 2)
  status    String    @default("active") @db.VarChar(16) // active, inactive
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  @@unique([venueId, code], map: "uk_courts_venue_code")
  @@index([tenantId, venueId], map: "idx_courts_tenant_venue")
  @@map("courts")
}

model CourtSchedule {
  id         BigInt    @id @default(autoincrement())
  tenantId   BigInt    @map("tenant_id")
  venueId    BigInt    @map("venue_id")
  courtId    BigInt    @map("court_id")
  playDate   DateTime  @map("play_date") @db.Date
  startTime  DateTime  @map("start_time") @db.Time()
  endTime    DateTime  @map("end_time") @db.Time()
  price      Decimal   @default(0) @db.Decimal(8, 2)
  status     String    @db.VarChar(16) // available, held, booked, maintenance, closed
  refType    String?   @map("ref_type") @db.VarChar(32)
  refId      BigInt?   @map("ref_id")
  version    Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz()

  @@unique([courtId, playDate, startTime], map: "uk_court_schedules_slot")
  @@index([tenantId, playDate, status], map: "idx_court_schedules_tenant_date")
  @@index([venueId, playDate], map: "idx_court_schedules_venue_date")
  @@map("court_schedules")
}

// ============================================================
// 4. Activity & Registration
// ============================================================

model Activity {
  id              BigInt    @id @default(autoincrement())
  tenantId        BigInt    @map("tenant_id")
  venueId         BigInt    @map("venue_id")
  type            String    @db.VarChar(32) // open_session, private_court, coach_lesson, tournament
  title           String    @db.VarChar(128)
  coverUrl        String?   @map("cover_url") @db.Text
  playDate        DateTime  @map("play_date") @db.Date
  startAt         DateTime  @map("start_at") @db.Timestamptz()
  endAt           DateTime  @map("end_at") @db.Timestamptz()
  capacity        Int       @default(0) @db.SmallInt
  joinCount       Int       @default(0) @map("join_count") @db.SmallInt
  waitlistCount   Int       @default(0) @map("waitlist_count") @db.SmallInt
  price           Decimal   @db.Decimal(8, 2)
  memberPrice     Decimal?  @map("member_price") @db.Decimal(8, 2)
  cancelPolicy    Json      @default("{}") @map("cancel_policy")
  status          String    @db.VarChar(16) // draft, published, registering, full, ongoing, finished, settled, canceled
  coachId         BigInt?   @map("coach_id")
  registerOpenAt  DateTime? @map("register_open_at") @db.Timestamptz()
  registerCloseAt DateTime? @map("register_close_at") @db.Timestamptz()
  createdBy       BigInt    @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()

  @@index([tenantId, status, playDate], map: "idx_activities_tenant_status_date")
  @@index([venueId, playDate], map: "idx_activities_venue_date")
  @@map("activities")
}

model ActivityCourt {
  id         BigInt   @id @default(autoincrement())
  activityId BigInt   @map("activity_id")
  scheduleId BigInt   @map("schedule_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([activityId, scheduleId], map: "uk_activity_courts_activity_schedule")
  @@map("activity_courts")
}

model ActivityShareToken {
  id             BigInt   @id @default(autoincrement())
  tenantId       BigInt   @map("tenant_id")
  activityId     BigInt   @map("activity_id")
  token          String   @unique @db.VarChar(64)
  sharerUserId   BigInt?  @map("sharer_user_id")
  channel        String?  @db.VarChar(32)
  registerCount  Int      @default(0) @map("register_count")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([activityId], map: "idx_activity_share_tokens_activity")
  @@map("activity_share_tokens")
}

model ActivityRegistration {
  id             BigInt    @id @default(autoincrement())
  tenantId       BigInt    @map("tenant_id")
  activityId     BigInt    @map("activity_id")
  userId         BigInt    @map("user_id")
  memberId       BigInt    @map("member_id")
  isWaitlist     Boolean   @default(false) @map("is_waitlist")
  extraCount     Int       @default(0) @map("extra_count") @db.SmallInt
  totalSlots     Int       @default(1) @map("total_slots") @db.SmallInt
  payAmount      Decimal   @default(0) @map("pay_amount") @db.Decimal(8, 2)
  payMethod      String?   @map("pay_method") @db.VarChar(32)
  status         String    @db.VarChar(16) // paying, confirmed, canceled, refunded, no_show, attended
  payOrderNo     String?   @map("pay_order_no") @db.VarChar(64)
  idempotencyKey String?   @map("idempotency_key") @db.VarChar(64)
  activeUserKey  String?   @map("active_user_key") @db.VarChar(128)
  shareToken     String?   @map("share_token") @db.VarChar(64)
  canceledAt     DateTime? @map("canceled_at") @db.Timestamptz()
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz()

  @@index([idempotencyKey], map: "uk_activity_registrations_idempotency")
  @@index([activeUserKey], map: "uk_activity_registrations_active_user")
  @@index([tenantId, userId, status], map: "idx_activity_registrations_tenant_user_status")
  @@index([activityId, status], map: "idx_activity_registrations_activity_status")
  @@map("activity_registrations")
}

model RegistrationParticipant {
  id             BigInt    @id @default(autoincrement())
  tenantId       BigInt    @map("tenant_id")
  activityId     BigInt    @map("activity_id")
  registrationId BigInt    @map("registration_id")
  userId         BigInt?   @map("user_id")
  displayName    String?   @map("display_name") @db.VarChar(64)
  phoneHash      String?   @map("phone_hash") @db.Char(64)
  seatNo         Int?      @map("seat_no") @db.SmallInt
  status         String    @db.VarChar(16) // confirmed, canceled, refunded, no_show, attended
  checkedInAt    DateTime? @map("checked_in_at") @db.Timestamptz()
  canceledAt     DateTime? @map("canceled_at") @db.Timestamptz()
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz()

  @@index([registrationId], map: "idx_registration_participants_registration")
  @@index([activityId, status], map: "idx_registration_participants_activity_status")
  // Partial unique index: active seat_no must be unique per activity
  // Implemented via raw SQL in migration - see notes in docs/04
  @@index([activityId, seatNo], map: "uk_registration_participants_active_seat")
  @@map("registration_participants")
}

// ============================================================
// 5. Wallet & Finance
// ============================================================

model Wallet {
  id           BigInt    @id @default(autoincrement())
  tenantId     BigInt    @map("tenant_id")
  userId       BigInt    @map("user_id")
  cashBalance  Decimal   @default(0) @map("cash_balance") @db.Decimal(12, 2)
  giftBalance  Decimal   @default(0) @map("gift_balance") @db.Decimal(12, 2)
  frozenBalance Decimal  @default(0) @map("frozen_balance") @db.Decimal(12, 2)
  version      BigInt    @default(0)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz()

  @@unique([tenantId, userId], map: "uk_wallets_tenant_user")
  @@map("wallets")
}

model WalletTransaction {
  id          BigInt   @id @default(autoincrement())
  tenantId    BigInt   @map("tenant_id")
  walletId    BigInt   @map("wallet_id")
  userId      BigInt   @map("user_id")
  direction   String   @db.Char(1) // D = debit, C = credit
  amount      Decimal  @db.Decimal(12, 2)
  subAccount  String   @map("sub_account") @db.VarChar(8) // cash, gift, frozen
  bizType     String   @map("biz_type") @db.VarChar(32)
  sourceType  String   @map("source_type") @db.VarChar(32)
  sourceId    BigInt   @map("source_id")
  remark      String?  @db.Text
  occurredAt  DateTime @default(now()) @map("occurred_at") @db.Timestamptz()
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([sourceType, sourceId, bizType, direction], map: "uk_wallet_transactions_source_biz")
  @@index([walletId, occurredAt(sort: Desc)], map: "idx_wallet_transactions_wallet_time")
  @@index([tenantId, userId, occurredAt], map: "idx_wallet_transactions_tenant_user")
  @@map("wallet_transactions")
}

model RechargePackage {
  id            BigInt    @id @default(autoincrement())
  tenantId      BigInt    @map("tenant_id")
  name          String    @db.VarChar(64)
  chargeAmount  Decimal   @map("charge_amount") @db.Decimal(12, 2)
  giftAmount    Decimal   @default(0) @map("gift_amount") @db.Decimal(12, 2)
  sort          Int       @default(0)
  status        String    @default("active") @db.VarChar(16) // active, inactive
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([tenantId, status, sort], map: "idx_recharge_packages_tenant_status")
  @@map("recharge_packages")
}

model RechargeOrder {
  id            BigInt    @id @default(autoincrement())
  tenantId      BigInt    @map("tenant_id")
  userId        BigInt    @map("user_id")
  rechargeNo    String    @unique @map("recharge_no") @db.VarChar(64)
  packageId     BigInt?   @map("package_id")
  chargeAmount  Decimal   @map("charge_amount") @db.Decimal(12, 2)
  giftAmount    Decimal   @default(0) @map("gift_amount") @db.Decimal(12, 2)
  payStatus     String    @map("pay_status") @db.VarChar(16) // created, paying, paid, canceled, failed
  paidAt        DateTime? @map("paid_at") @db.Timestamptz()
  outTradeNo    String?   @map("out_trade_no") @db.VarChar(64)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([tenantId, userId, createdAt], map: "idx_recharge_orders_tenant_user")
  @@map("recharge_orders")
}

model PaymentOrder {
  id             BigInt    @id @default(autoincrement())
  tenantId       BigInt    @map("tenant_id")
  userId         BigInt    @map("user_id")
  outTradeNo     String    @unique @map("out_trade_no") @db.VarChar(64)
  bizType        String    @map("biz_type") @db.VarChar(32)
  bizOrderNo     String    @map("biz_order_no") @db.VarChar(64)
  attemptNo      Int       @default(1) @map("attempt_no")
  payChannel     String    @map("pay_channel") @db.VarChar(32)
  amount         Decimal   @db.Decimal(12, 2)
  status         String    @db.VarChar(16) // created, paying, paid, canceled, failed, expired
  paidAt         DateTime? @map("paid_at") @db.Timestamptz()
  canceledAt     DateTime? @map("canceled_at") @db.Timestamptz()
  notifyPayload  Json?     @map("notify_payload")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([bizType, bizOrderNo, attemptNo], map: "uk_payment_orders_biz_attempt")
  @@index([tenantId, userId, createdAt], map: "idx_payment_orders_tenant_user")
  @@index([bizType, bizOrderNo, status], map: "idx_payment_orders_biz")
  @@map("payment_orders")
}

model RefundOrder {
  id           BigInt    @id @default(autoincrement())
  tenantId     BigInt    @map("tenant_id")
  userId       BigInt    @map("user_id")
  refundNo     String    @unique @map("refund_no") @db.VarChar(64)
  paymentId    BigInt    @map("payment_id")
  bizType      String    @map("biz_type") @db.VarChar(32)
  bizOrderNo   String    @map("biz_order_no") @db.VarChar(64)
  refundAmount Decimal   @map("refund_amount") @db.Decimal(12, 2)
  status       String    @db.VarChar(16) // pending, success, failed
  refundedAt   DateTime? @map("refunded_at") @db.Timestamptz()
