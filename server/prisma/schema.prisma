  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([tenantId, bizType, status, effectiveFrom], map: "idx_commission_rules_tenant_biz")
  @@map("commission_rules")
}

model SettlementOrder {
  id              BigInt    @id @default(autoincrement())
  tenantId        BigInt    @map("tenant_id")
  settlementNo    String    @unique @map("settlement_no") @db.VarChar(64)
  periodStart     DateTime  @map("period_start") @db.Date
  periodEnd       DateTime  @map("period_end") @db.Date
  grossAmount     Decimal   @default(0) @map("gross_amount") @db.Decimal(12, 2)
  refundAmount    Decimal   @default(0) @map("refund_amount") @db.Decimal(12, 2)
  commissionAmount Decimal  @default(0) @map("commission_amount") @db.Decimal(12, 2)
  payableAmount   Decimal   @default(0) @map("payable_amount") @db.Decimal(12, 2)
  status          String    @db.VarChar(16) // draft, confirmed, paying, paid, failed
  paidAt          DateTime? @map("paid_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

