  @@index([parentId, sort], map: "idx_product_categories_parent")
  @@map("product_categories")
}

model Product {
  id           BigInt    @id @default(autoincrement())
  tenantId     BigInt    @default(0) @map("tenant_id")
  categoryId   BigInt    @map("category_id")
  title        String    @db.VarChar(128)
  coverUrl     String?   @map("cover_url") @db.Text
  detailHtml   String?   @map("detail_html") @db.Text
  deliveryType String    @map("delivery_type") @db.VarChar(16) // virtual, self_pickup, express
