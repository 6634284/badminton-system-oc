// 10. System: Notifications, Outbox, Audit
// ============================================================

model Notification {
  id        BigInt    @id @default(autoincrement())
  tenantId  BigInt    @map("tenant_id")
  userId    BigInt    @map("user_id")
  bizType   String    @map("biz_type") @db.VarChar(32)
  bizId     String?   @map("biz_id") @db.VarChar(64)
  title     String    @db.VarChar(128)
  content   String    @db.Text
  channel   String    @db.VarChar(16) // in_app, sms, push, wechat
  isRead    Boolean   @default(false) @map("is_read")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  readAt    DateTime? @map("read_at") @db.Timestamptz()

  @@index([userId, isRead, createdAt], map: "idx_notifications_user_unread")
  @@map("notifications")
}

model NotificationTemplate {
  id        BigInt   @id @default(autoincrement())
  tenantId  BigInt   @map("tenant_id")
  key       String   @db.VarChar(64) // e.g. registration_success, payment_success
  name      String   @db.VarChar(128)
  type      String   @db.VarChar(16) // in_app, sms, wechat
  title     String   @db.VarChar(128)
  content   String   @db.Text
  variables Json?    @map("variables") // array of variable names like ["activityName", "date"]
  status    String   @default("active") @db.VarChar(16) // active, disabled
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([tenantId, key], map: "uk_notification_templates_tenant_key")
  @@index([tenantId, status], map: "idx_notification_templates_tenant_status")
  @@map("notification_templates")
}

model OutboxEvent {
  id            BigInt    @id @default(autoincrement())
  tenantId      BigInt    @map("tenant_id")
  eventType     String    @map("event_type") @db.VarChar(64)
  aggregateType String    @map("aggregate_type") @db.VarChar(64)
  aggregateId   BigInt    @map("aggregate_id")
  payloadJson   Json      @map("payload_json")
  status        String    @default("pending") @db.VarChar(16) // pending, processing, sent, failed
  retryCount    Int       @default(0) @map("retry_count")
  nextRetryAt   DateTime? @map("next_retry_at") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([status, nextRetryAt, createdAt], map: "idx_outbox_events_status_retry")
  @@map("outbox_events")
}

model AuditLog {
  id           BigInt   @id @default(autoincrement())
  tenantId     BigInt   @default(0) @map("tenant_id")
  operatorId   BigInt   @map("operator_id")
  operatorType String   @map("operator_type") @db.VarChar(32)
  category     String   @db.VarChar(32)
  action       String   @db.VarChar(64)
  targetType   String?  @map("target_type") @db.VarChar(32)
  targetId     String?  @map("target_id") @db.VarChar(64)
  riskLevel    Int      @default(1) @map("risk_level") @db.SmallInt
  beforeJson   Json?    @map("before_json")
  afterJson    Json?    @map("after_json")
  payload      Json?
  ip           String?  @db.VarChar(64)
  userAgent    String?  @map("user_agent") @db.Text
  traceId      String?  @map("trace_id") @db.VarChar(64)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([tenantId, createdAt], map: "idx_audit_logs_tenant_time")
  @@index([category, createdAt], map: "idx_audit_logs_category")
  @@index([targetType, targetId], map: "idx_audit_logs_target")
  @@map("audit_logs")
}
