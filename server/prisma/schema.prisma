model Coupon {
  id            BigInt    @id @default(autoincrement())
  tenantId      BigInt    @map("tenant_id")
  name          String    @db.VarChar(128)
  type          String    @db.VarChar(16) // discount, cash, condition
  discountValue Decimal   @map("discount_value") @db.Decimal(8, 2)
  applyScope    String    @map("apply_scope") @db.VarChar(16) // all, activity, mall, category
  applyTargetId BigInt?   @map("apply_target_id")
  stock         Int       @default(0)
  perUserLimit  Int       @default(1) @map("per_user_limit")
  validType     Int       @db.SmallInt // 1 = fixed date range, 2 = relative days
  validFrom     DateTime? @map("valid_from") @db.Timestamptz()
  validTo       DateTime? @map("valid_to") @db.Timestamptz()
  validDays     Int?
  status        String    @default("active") @db.VarChar(16) // active, inactive
  minAmount     Decimal?  @map("min_amount") @db.Decimal(10, 2)
  maxDiscount   Decimal?  @map("max_discount") @db.Decimal(10, 2)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([tenantId, status, deletedAt], map: "idx_coupons_tenant_status")
  @@map("coupons")
}

model UserCoupon {
  id         BigInt    @id @default(autoincrement())
  tenantId   BigInt    @map("tenant_id")
  userId     BigInt    @map("user_id")
  couponId   BigInt    @map("coupon_id")
  status     String    @db.VarChar(16) // unused, locked, used, expired
  validFrom  DateTime? @map("valid_from") @db.Timestamptz()
  validTo    DateTime? @map("valid_to") @db.Timestamptz()
  usedAt     DateTime? @map("used_at") @db.Timestamptz()
  receivedAt DateTime  @default(now()) @map("received_at") @db.Timestamptz()

  @@index([userId, status, validTo], map: "idx_user_coupons_user_status")
  @@map("user_coupons")
}

