# Badminton System - Environment Variables

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/badminton?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=bs:

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Server Ports
PORT=3000
ADMIN_PORT=3001
OPEN_PORT=3002
WS_PORT=3003

# Wechat (微信小程序)
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_MCH_ID=
WECHAT_API_KEY=

# Alipay (支付宝)
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# SMS (短信服务)
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# OSS (对象存储)
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=
OSS_REGION=

# Environment
NODE_ENV=development
